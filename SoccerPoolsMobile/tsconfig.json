{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "components/*": ["./components/*"],
      "utils/*": ["./utils/*"],
      "hooks/*": ["./hooks/*"],
      "services/*": ["./services/*"],
      "contexts/*": ["./contexts/*"],
      "modals/*": ["./modals/*"],
      "theme": ["./theme/index"],
      "theme/*": ["./theme/*"]
    }
  },
  "include": [
    "types.d.ts",
    "types.ts",
    "constants.ts",
    "components",
    "app",
    "utils",
    "hooks",
    "services",
    "contexts",
    "modals",
    "theme"
  ]
}
